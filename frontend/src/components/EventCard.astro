---
interface Props {
  content: {
    type: 'video' | 'image';
    src: string;
    title?: string;
    subtitle?: string;
  };
}

const { content } = Astro.props;
---

<div class="group relative flex-shrink-0 w-[280px] h-[400px] sm:w-[320px] sm:h-[480px] rounded-[2.5rem] overflow-hidden bg-gray-100 shadow-xl transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl">
  {content.type === 'video' ? (
    <video 
      src={content.src} 
      autoplay 
      muted 
      loop 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover"
    />
  ) : (
    <img 
      src={content.src} 
      alt={content.title || "Event"} 
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    />
  )}

  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex flex-col justify-end p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
    {content.subtitle && <span class="text-white/60 text-xs font-bold uppercase tracking-widest mb-2">{content.subtitle}</span>}
    {content.title && <h4 class="text-white text-2xl font-black leading-tight">{content.title}</h4>}
    
    <div class="mt-4 flex gap-2">
      <div class="h-1.5 w-8 bg-white rounded-full"></div>
      <div class="h-1.5 w-4 bg-white/30 rounded-full"></div>
      <div class="h-1.5 w-4 bg-white/30 rounded-full"></div>
    </div>
  </div>

  <!-- Decorative Badge (like the smiley in reference) -->
  <div class="absolute top-6 left-6 w-10 h-10 bg-white/10 backdrop-blur-md border border-white/20 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 scale-50 group-hover:scale-100">
    <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  </div>
</div>
