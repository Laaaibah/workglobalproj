---
import { content } from '../data/content';

export interface Props {
  title?: string;
}
const { title = content.comparison.title } = Astro.props;
const { oldWay, newWay } = content.comparison;

// SVGs using a function to avoid repeating class names
const getIcon = (name: string, className: string) => {
  const icons: Record<string, string> = {
    'file-text': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    'megaphone': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
    'search': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
    'map-pin': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    'clock': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    'video': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>`,
    'check-circle': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    'sparkles': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>`,
    'globe': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    'zap': `<svg class="${className}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  };
  return icons[name] || '';
};
---

<section class="w-full py-20 sm:py-28 overflow-hidden px-4 sm:px-12 lg:px-20 flex flex-col items-center">
  <h2 class="text-4xl sm:text-6xl font-bold text-[#053F5C] leading-tight text-center mb-16 sm:mb-20" data-aos="fade-up">{title}</h2>

  <div class="flex flex-col md:flex-row items-stretch justify-center gap-6 sm:gap-10 w-full max-w-5xl relative" data-aos="fade-up" data-aos-delay="100">
    
    <!-- Old Way Card -->
    <div class="group bg-[#C6DFF1] rounded-[2rem] px-6 py-6 sm:px-10 sm:py-8 w-full md:flex-1 lg:max-w-[420px] shadow-[0_20px_50px_rgba(5,63,92,0.05)] transform md:-rotate-1 lg:-rotate-2 flex flex-col transition-all duration-500 hover:-translate-y-4 hover:shadow-[0_30px_60px_rgba(5,63,92,0.1)] overflow-hidden relative border border-white/50">
      <div class="absolute -right-16 -top-16 w-48 h-48 bg-[#8dc8ee]/30 rounded-full blur-3xl group-hover:bg-[#8dc8ee]/50 transition-colors duration-500"></div>
      
      <h3 class="text-2xl sm:text-3xl font-bold text-[#053F5C] mb-4 relative z-10">{oldWay.title}</h3>
      <ul class="space-y-3 text-base sm:text-lg text-[#053F5C] font-semibold relative z-10 w-full">
        {oldWay.items.map(item => (
          <li class="flex items-center gap-3 group/item w-full bg-white/40 px-3 py-2 rounded-2xl transition-all duration-300 hover:bg-white hover:scale-[1.02] hover:shadow-sm cursor-default">
            <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center flex-shrink-0 text-slate-500 group-hover/item:text-slate-700 group-hover/item:scale-110 transition-transform duration-300">
               <Fragment set:html={getIcon(item.icon, "w-4 h-4")} />
            </div>
            <span class="leading-tight">{item.text}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- VS Text -->
    <div class="hidden lg:flex absolute left-1/2 top-[50%] -translate-x-1/2 -translate-y-1/2 z-20 text-4xl sm:text-5xl font-bold text-[#053F5C]/40 italic mix-blend-multiply drop-shadow-md hover:scale-110 hover:text-[#053F5C]/60 transition-all duration-300">
      VS.
    </div>

    <!-- New Way Card -->
    <div class="group bg-[#8dc8ee] rounded-[2rem] px-6 py-6 sm:px-10 sm:py-8 w-full md:flex-1 lg:max-w-[420px] shadow-[0_20px_50px_rgba(141,200,238,0.4)] transform md:rotate-1 lg:rotate-2 flex flex-col z-0 transition-all duration-500 hover:-translate-y-4 hover:shadow-[0_40px_80px_rgba(141,200,238,0.6)] overflow-hidden relative border border-white/20">
      <div class="absolute -right-16 -top-16 w-64 h-64 bg-white/20 rounded-full blur-2xl group-hover:scale-125 transition-transform duration-700"></div>

      <h3 class="text-2xl sm:text-3xl font-bold text-[#053F5C] mb-4 relative z-10">{newWay.title}</h3>
      <ul class="space-y-3 text-base sm:text-lg text-[#053F5C] font-semibold relative z-10 w-full">
        {newWay.items.map(item => (
          <li class="flex items-center gap-3 group/item w-full bg-white/20 px-3 py-2 rounded-2xl backdrop-blur-sm transition-all duration-300 hover:bg-white/40 hover:scale-[1.02] hover:shadow-md cursor-default border border-white/10 hover:border-white/30">
            <div class="w-8 h-8 rounded-full bg-white text-[#8dc8ee] flex items-center justify-center flex-shrink-0 group-hover/item:text-[#053F5C] shadow-sm group-hover/item:shadow-md group-hover/item:scale-110 group-hover/item:rotate-12 transition-all duration-300">
              <Fragment set:html={getIcon(item.icon, "w-4 h-4")} />
            </div>
            <span>{item.text}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>
