---
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/background.png?url';
import FAQ from '../components/faq.astro';
import logoIcon from '../assets/logo icon hi.png?url';
import content from '../data/content.js';

const jobFaqs = content.support['job-seeker'].faqs;
const orgFaqs = content.support.organization.faqs;
const contact = content.support.contact;
---

<Layout title="Support Center - WorkGlobal" navActive="support">
  <style define:vars={{ bgImage: `url(${bgImage})` }}>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --navy: #053F5C;
        --light-blue: #86C5FF;
        --pink: #ec4492;
        --accent-gradient: linear-gradient(90deg, rgb(62, 134, 198) 0%, rgb(166, 102, 170) 24.44045608108108%, rgb(236, 68, 146) 50.77597128378378%, rgb(238, 68, 84) 75.87274774774775%, rgb(240, 84, 39) 100%);
        --bg: #ddeef8;
        --card-bg: #8dc8ee;
      }

      html { font-size: 18px; }

      body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg);
        min-height: 100vh;
        padding: 0;
      }

      .bg-layer {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: var(--bgImage);
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        opacity: 1;
        z-index: -1;
        pointer-events: none;
      }

      .page-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 96px;
        width: 100%;
        min-height: 100vh;
        padding: clamp(150px, 16vw, 190px) 20px 40px;
      }

      /* ── LEFT PANEL ── */
      .left-panel {
        flex: 1;
        max-width: 380px;
        display: flex;
        flex-direction: column;
        gap: 28px;
        transform: translateX(-10px);
      }

      .mascot-placeholder {
        width: 160px;
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .mascot-img {
        width: 160px;
        height: auto;
        display: block;
      }

      .heading-block h1 {
        font-size: 2.05rem;
        font-weight: 800;
        color: var(--navy);
        letter-spacing: 0;
        text-transform: none;
        line-height: 1.25;
      }

      .heading-block p {
        margin-top: 10px;
        font-size: 1.05rem;
        font-weight: 500;
        color: #4a6a80;
        line-height: 1.7;
        max-width: 320px;
      }

      .contact-list {
        display: flex;
        flex-direction: column;
        gap: 18px;
        list-style: none;
      }

      .contact-list li {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .icon-circle {
        width: 50px;
        height: 50px;
        min-width: 50px;
        border-radius: 50%;
        background: var(--accent-gradient);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .icon-circle svg {
        width: 22px;
        height: 22px;
        fill: #fff;
      }

      .contact-list li span {
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.5;
      }

      /* Social links */
      .social-list {
        display: flex;
        gap: 12px;
        margin-top: 8px;
      }

      .social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 8px;
        background: rgba(5,63,92,0.06);
        transition: transform 0.12s ease, box-shadow 0.12s ease;
        text-decoration: none;
      }

      .social-link:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 18px rgba(5,63,92,0.12);
      }

      .social-link svg {
        width: 20px;
        height: 20px;
        display: block;
        fill: var(--navy);
      }

      /* ── RIGHT PANEL — FORM CARD ── */
      .form-card {
        flex: 0 0 480px;
        background: var(--card-bg);
        border-radius: 30px;
        padding: 42px 34px 44px;
        box-shadow: rgb(255, 255, 255) 0px 0px 10px 0px inset;
        opacity: 1;
        will-change: transform;
        transform: translateX(10px);
      }

      .form-group {
        display: flex;
        flex-direction: column;
        gap: 7px;
        margin-bottom: 18px;
      }

      .form-group:last-of-type {
        margin-bottom: 26px;
      }

      .form-group label {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--navy);
        letter-spacing: 0.03em;
      }

      .form-group input,
      .form-group textarea {
        width: 100%;
        background: #ddeef8;
        border: none;
        border-radius: 12px;
        padding: 11px 14px;
        font-family: 'Inter', sans-serif;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--navy);
        outline: none;
        transition: box-shadow 0.2s;
        resize: none;
      }

      .form-group input:focus,
      .form-group textarea:focus {
        box-shadow: 0 0 0 2px var(--pink);
      }

      .form-group textarea {
        height: 120px;
      }

      .btn-signup {
        width: auto;
        min-width: 122px;
        margin: 0 auto;
        display: block;
        padding: 9px 16px;
        background: #ffffff;
        border: none;
        border-radius: 999px;
        color: #053F5C;
        font-family: 'Inter', sans-serif;
        font-size: 0.8rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        cursor: pointer;
        box-shadow: 0 6px 16px rgba(5, 63, 92, 0.18);
        transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      }

      .btn-signup:hover {
        background: #f3f8ff;
        transform: translateY(-1px);
        box-shadow: 0 8px 18px rgba(5, 63, 92, 0.22);
      }

      .btn-signup:active {
        transform: translateY(0);
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 700px) {
        .page-wrapper {
          flex-direction: column;
          gap: 48px;
          padding: 136px 16px 36px;
        }

        .left-panel,
        .form-card {
          transform: none;
        }

        .form-card {
          flex: none;
          width: 100%;
          max-width: 400px;
        }
      }
    </style>

    <div class="bg-layer"></div>

    <!-- ── CONTACT HERO ── -->
    <div class="page-wrapper">

      <!-- LEFT -->
      <div class="left-panel">

        <div class="mascot-placeholder">
          <img src={logoIcon} alt="WorkGlobal mascot" class="mascot-img" />
        </div>

        <div class="heading-block">
          <h1>Get In Touch Today</h1>
          <p>We're happy to hear from you! Don't hesitate to contact us. Our team is here to assist you with any questions you may have.</p>
        </div>

        <ul class="contact-list">
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
              </svg>
            </div>
              <span id="contact-phone">{contact.number}</span>
          </li>
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </div>
            <span id="contact-email">{contact.email}</span>
          </li>
          <li>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/>
              </svg>
            </div>
            <span id="contact-location">{contact.location}</span>
          </li>
        </ul>
        <div class="social-list" aria-label="Follow us">
          <a class="social-link" href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M7 2C4.2 2 2 4.2 2 7v10c0 2.8 2.2 5 5 5h10c2.8 0 5-2.2 5-5V7c0-2.8-2.2-5-5-5H7zm10 2c1.7 0 3 1.3 3 3v10c0 1.7-1.3 3-3 3H7c-1.7 0-3-1.3-3-3V7c0-1.7 1.3-3 3-3h10zM12 7.5A4.5 4.5 0 1 0 12 16.5 4.5 4.5 0 1 0 12 7.5zm0 2A2.5 2.5 0 1 1 12 14 2.5 2.5 0 1 1 12 9.5zM17.8 6.3a.9.9 0 1 1 0 1.8.9.9 0 0 1 0-1.8z"/></svg>
          </a>
          <a class="social-link" href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22 12a10 10 0 1 0-11.5 9.9v-7h-2.4V12h2.4V9.7c0-2.4 1.4-3.8 3.6-3.8 1 0 2 .08 2 .08v2.2h-1.1c-1.1 0-1.5.72-1.5 1.45V12h2.6l-.4 2.9h-2.2v7A10 10 0 0 0 22 12z"/></svg>
          </a>
          <a class="social-link" href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M4.98 3.5a2.5 2.5 0 1 1 .02 0zM3 8.98h4v12H3v-12zM9 8.98h3.8v1.64h.05c.53-1 1.82-2.05 3.74-2.05 4 0 4.74 2.6 4.74 6v6.41h-4v-5.68c0-1.35 0-3.08-1.88-3.08-1.88 0-2.16 1.46-2.16 2.98v5.78H9v-12z"/></svg>
          </a>
        </div>
      </div>

      <!-- RIGHT — FORM CARD -->
      <div class="form-card">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" autocomplete="name" />
        </div>

        <div class="form-group">
          <label for="number">Number</label>
          <input type="tel" id="number" name="number" autocomplete="tel" />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" autocomplete="email" />
        </div>

        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message"></textarea>
        </div>

        <button class="btn-signup" type="button">SEND</button>
      </div>

    </div>

    <!-- ── FAQ SECTION ── -->
    <div id="faq-job" data-role="jobseeker">
      <FAQ
        items={jobFaqs}
        title="Frequently Asked Questions"
        subtitle="Everything you need to know about Work Global."
      />
    </div>

    <div id="faq-org" data-role="organization" style="display:none;">
      <FAQ
        items={orgFaqs}
        title="Frequently Asked Questions"
        subtitle="Everything you need to know about Work Global."
      />
    </div>

    <script is:inline>
      (() => {
        const gateKey = 'wg-user-role';
        const role = window.localStorage.getItem(gateKey);
        const job = document.getElementById('faq-job');
        const org = document.getElementById('faq-org');

        if (role === 'organization') {
          if (job) job.style.display = 'none';
          if (org) org.style.display = 'block';
        } else {
          if (job) job.style.display = 'block';
          if (org) org.style.display = 'none';
        }

        if (typeof setupFaqAccordions === 'function') setupFaqAccordions();
      })();
    </script>

</Layout>