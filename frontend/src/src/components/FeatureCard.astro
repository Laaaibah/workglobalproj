---
interface Props {
  images: string[];
  align?: 'left' | 'right';
  reverseStack?: boolean;
  tiltDirection?: 'left' | 'right';
  swipeable?: boolean;
}

const { images, align = 'left', reverseStack = false, tiltDirection = 'left', swipeable = false } = Astro.props;
---

{swipeable ? (
  <!-- ═══ SWIPE MODE ═══ -->
  <div class={`flex items-center justify-center ${align === 'left' ? 'lg:justify-start' : 'lg:justify-end'} swipe-stack-wrapper`}>
    <!-- X Button (Left Side) -->
    <button type="button" class="swipe-btn swipe-btn-x" aria-label="Pass">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <!-- Card Stack -->
    <div class="swipe-stack">
      {images.map((image, i) => (
        <div
          class={`swipe-card ${i === 0 ? 'active' : ''}`}
          data-index={i}
          style={`z-index: ${images.length - i};`}
        >
          <div class="swipe-card-inner">
            <div class="swipe-card-statusbar">
              <span class="text-[10px] font-bold text-white">9:41</span>
              <div class="flex gap-1.5 opacity-80">
                <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"/></svg>
              </div>
            </div>
            <div class="swipe-card-notch"><div class="swipe-card-notch-bar"></div></div>
            <div class="swipe-card-image">
              <img src={image} alt="App feature" />
              <div class="swipe-card-overlay">
                <div class="w-12 h-1 bg-white/40 rounded-full mb-4"></div>
                <div class="h-4 w-3/4 bg-white/20 rounded mb-2"></div>
                <div class="h-4 w-1/2 bg-white/10 rounded"></div>
              </div>
            </div>
            <div class="swipe-stamp stamp-like">LIKE</div>
            <div class="swipe-stamp stamp-nope">NOPE</div>
            <div class="swipe-card-border"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Heart Button (Right Side) -->
    <button type="button" class="swipe-btn swipe-btn-heart" aria-label="Like">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    </button>
  </div>
) : (
  <!-- ═══ STATIC PHONE STACK MODE (Original) ═══ -->
  <div class={`flex justify-center items-center ${align === 'left' ? 'lg:justify-start' : 'lg:justify-end'} -space-x-24 sm:-space-x-32 md:-space-x-44 phone-stack-container h-[420px] sm:h-[550px] isolate scale-[0.8] sm:scale-100 transition-transform duration-500`}>
    {images.map((image, i) => {
      const configIndex = reverseStack ? (2 - i) : i;
      const tiltMult = tiltDirection === 'right' ? 1 : -1;
      const configs = [
        { rotate: `${8 * tiltMult}deg`, z: "10", scale: "0.85", opacity: "0.8", delay: 200, shadow: "shadow-lg" },
        { rotate: `${4 * tiltMult}deg`,  z: "20", scale: "0.92", opacity: "0.9", delay: 100, shadow: "shadow-2xl" },
        { rotate: "0deg",              z: "30", scale: "1.0",  opacity: "1.0", delay: 0,   shadow: "shadow-[20px_40px_100px_-20px_rgba(0,0,0,0.5)]" },
      ];
      const config = configs[configIndex] || configs[2];

      return (
        <div
          class={`feature-card relative w-[200px] h-[360px] sm:w-[280px] sm:h-[500px] rounded-[2.5rem] sm:rounded-[3rem] border-[6px] sm:border-[10px] border-white ${config.shadow} overflow-hidden transition-all duration-700 bg-black group`}
          style={`z-index: ${config.z}; transform: rotate(${config.rotate}) scale(${config.scale}); opacity: ${config.opacity}; transition-delay: ${config.delay}ms;`}
        >
          <div class="absolute top-0 left-0 w-full h-8 flex justify-between items-center px-8 pt-4 z-20 pointer-events-none">
            <span class="text-[10px] font-bold text-white">9:41</span>
            <div class="flex gap-1.5 opacity-80">
              <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2z"/></svg>
            </div>
          </div>
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-7 bg-white rounded-b-3xl z-30">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-1 bg-black/20 rounded-full"></div>
          </div>
          <div class="absolute inset-0 z-10">
            <img src={image} alt="App feature" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex flex-col justify-end p-8">
              <div class="w-12 h-1 bg-white/40 rounded-full mb-4"></div>
              <div class="h-4 w-3/4 bg-white/20 rounded mb-2"></div>
              <div class="h-4 w-1/2 bg-white/10 rounded"></div>
            </div>
          </div>
          <div class="absolute inset-0 z-15 pointer-events-none border-[1px] border-white/20 rounded-[inherit]"></div>
        </div>
      );
    })}
  </div>
)}

<style is:global>
  /* ═══ STATIC PHONE STACK STYLES ═══ */
  .feature-card {
    will-change: transform, z-index;
    cursor: pointer;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .phone-stack-container:hover .feature-card {
    opacity: 0.6;
    filter: blur(2px) grayscale(0.2);
  }

  .phone-stack-container .feature-card:hover {
    opacity: 1 !important;
    scale: 1.05 !important;
    rotate: 0deg !important;
    filter: none !important;
    translate: 0 -30px;
    z-index: 50 !important;
    box-shadow: 0 50px 100px -20px rgba(0,0,0,0.5);
  }

  /* ═══ SWIPE CARD STYLES ═══ */
  .swipe-stack-wrapper {
    perspective: 1200px;
    gap: 1.5rem;
  }

  .swipe-stack {
    position: relative;
    width: 260px;
    height: 460px;
  }

  @media (min-width: 640px) {
    .swipe-stack {
      width: 300px;
      height: 540px;
    }
  }

  .swipe-card {
    position: absolute;
    inset: 0;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
    will-change: transform, opacity;
    pointer-events: none;
  }

  .swipe-card.active {
    pointer-events: auto;
  }

  .swipe-card.swipe-right {
    animation: swipeRight 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .swipe-card.swipe-left {
    animation: swipeLeft 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes swipeRight {
    0%   { transform: translateX(0) rotate(0deg); opacity: 1; }
    100% { transform: translateX(150%) rotate(20deg); opacity: 0; }
  }

  @keyframes swipeLeft {
    0%   { transform: translateX(0) rotate(0deg); opacity: 1; }
    100% { transform: translateX(-150%) rotate(-20deg); opacity: 0; }
  }

  .swipe-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 2.5rem;
    border: 10px solid #fff;
    overflow: hidden;
    background: #000;
    box-shadow: 0 20px 60px -15px rgba(0,0,0,0.35), 0 8px 20px -8px rgba(0,0,0,0.2);
  }

  .swipe-card.active .swipe-card-inner {
    box-shadow: 0 30px 80px -15px rgba(0,0,0,0.4), 0 15px 35px -10px rgba(0,0,0,0.25);
  }

  .swipe-card-statusbar {
    position: absolute; top: 0; left: 0; width: 100%; height: 2rem;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 2rem 0; z-index: 20; pointer-events: none;
  }

  .swipe-card-notch {
    position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 8rem; height: 1.75rem; background: #fff;
    border-radius: 0 0 1.5rem 1.5rem; z-index: 30;
  }

  .swipe-card-notch-bar {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 2.5rem; height: 0.25rem; background: rgba(0,0,0,0.15); border-radius: 9999px;
  }

  .swipe-card-image {
    position: absolute; inset: 0; z-index: 10;
  }

  .swipe-card-image img {
    width: 100%; height: 100%; object-fit: cover;
  }

  .swipe-card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.6), transparent, transparent);
    display: flex; flex-direction: column; justify-content: flex-end; padding: 2rem;
  }

  .swipe-card-border {
    position: absolute; inset: 0; z-index: 15; pointer-events: none;
    border: 1px solid rgba(255,255,255,0.2); border-radius: inherit;
  }

  .swipe-stamp {
    position: absolute; top: 4rem; z-index: 25;
    font-size: 2.2rem; font-weight: 900; letter-spacing: 0.1em;
    padding: 6px 18px; border-radius: 12px; border-width: 4px;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .stamp-like {
    right: 1.2rem; color: #22c55e; border-color: #22c55e;
    transform: rotate(15deg) scale(0.8);
  }

  .stamp-nope {
    left: 1.2rem; color: #ef4444; border-color: #ef4444;
    transform: rotate(-15deg) scale(0.8);
  }

  .swipe-card.show-like .stamp-like {
    opacity: 1; transform: rotate(15deg) scale(1);
  }

  .swipe-card.show-nope .stamp-nope {
    opacity: 1; transform: rotate(-15deg) scale(1);
  }

  /* Buttons */
  .swipe-btn {
    width: 64px; height: 64px; border-radius: 50%; border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; flex-shrink: 0;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .swipe-btn svg { width: 28px; height: 28px; }

  .swipe-btn-x {
    background: linear-gradient(145deg, #fff 0%, #dbeafe 100%);
    color: #3b82f6;
    box-shadow: 0 6px 20px rgba(59, 130, 246, 0.25);
  }

  .swipe-btn-x:hover {
    transform: scale(1.12);
    box-shadow: 0 10px 30px rgba(59, 130, 246, 0.4);
  }

  .swipe-btn-x:active { transform: scale(0.95); }

  .swipe-btn-heart {
    background: linear-gradient(145deg, #fff 0%, #fee2e2 100%);
    color: #ef4444;
    box-shadow: 0 6px 20px rgba(239, 68, 68, 0.25);
  }

  .swipe-btn-heart:hover {
    transform: scale(1.12);
    box-shadow: 0 10px 30px rgba(239, 68, 68, 0.4);
  }

  .swipe-btn-heart:active { transform: scale(0.95); }
</style>

<script>
  function setupSwipeStacks() {
    document.querySelectorAll('.swipe-stack').forEach((stack) => {
      if ((stack as HTMLElement).dataset.bound === 'true') return;
      (stack as HTMLElement).dataset.bound = 'true';

      const cards = Array.from(stack.querySelectorAll('.swipe-card')) as HTMLElement[];
      const wrapper = stack.closest('.swipe-stack-wrapper');
      const btnX = wrapper?.querySelector('.swipe-btn-x');
      const btnHeart = wrapper?.querySelector('.swipe-btn-heart');

      if (!cards.length || !btnX || !btnHeart) return;

      let currentIndex = 0;

      function updateStack() {
        cards.forEach((card) => {
          card.classList.remove('active', 'swipe-left', 'swipe-right', 'show-like', 'show-nope');
          card.style.display = '';
          card.style.zIndex = '';
          card.style.transform = '';
          card.style.opacity = '';
          card.style.pointerEvents = '';
        });

        for (let i = 0; i < cards.length; i++) {
          const cardIdx = (currentIndex + i) % cards.length;
          const card = cards[cardIdx];

          if (i === 0) {
            card.classList.add('active');
            card.style.zIndex = '30';
            card.style.transform = 'scale(1) translateX(0) translateY(0)';
            card.style.opacity = '1';
          } else if (i === 1) {
            card.style.zIndex = '20';
            card.style.transform = 'scale(0.92) translateX(-24px) translateY(8px)';
            card.style.opacity = '0.7';
          } else if (i === 2) {
            card.style.zIndex = '10';
            card.style.transform = 'scale(0.84) translateX(24px) translateY(8px)';
            card.style.opacity = '0.5';
          } else {
            card.style.display = 'none';
          }
        }
      }

      function swipe(direction: 'left' | 'right') {
        const activeCard = cards[currentIndex % cards.length];
        if (!activeCard) return;

        activeCard.classList.add(direction === 'right' ? 'show-like' : 'show-nope');

        setTimeout(() => {
          activeCard.classList.add(direction === 'right' ? 'swipe-right' : 'swipe-left');

          setTimeout(() => {
            currentIndex = (currentIndex + 1) % cards.length;
            updateStack();
          }, 450);
        }, 150);
      }

      btnX.addEventListener('click', () => swipe('left'));
      btnHeart.addEventListener('click', () => swipe('right'));

      updateStack();
    });
  }

  setupSwipeStacks();
  document.addEventListener('astro:page-load', setupSwipeStacks);
  document.addEventListener('astro:after-swap', setupSwipeStacks);
</script>
