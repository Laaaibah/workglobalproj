---
import footerBg from '../assets/footer.png?url';
---

<footer 
  class="relative w-full text-white bg-cover bg-top overflow-hidden"
  style={{backgroundImage: `url(${footerBg})`}}
>
  {/* Footer container with padding */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 sm:pt-20 md:pt-24 pb-4 sm:pb-6 md:pb-8">
    {/* Main footer content */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-4 sm:mb-8">
      {/* Left section - Logo and tagline */}
      <div class="flex flex-col justify-center order-1 sm:order-1">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-1">workglobal</h2>
        <p class="text-sm sm:text-base md:text-lg font-light">Swipe. Match. Work</p>
      </div>

      {/* Center section - Newsletter input */}
      <div class="flex items-center justify-center order-3 sm:order-2 col-span-1 sm:col-span-1 lg:col-span-1">
        <div class="flex w-full max-w-sm">
          <input 
            type="email" 
            placeholder="Enter your email" 
            class="flex-1 px-3 sm:px-4 md:px-6 py-2 rounded-l-full bg-white text-gray-800 placeholder-gray-400 outline-none text-xs sm:text-sm md:text-base"
          />
          <button class="px-4 sm:px-6 md:px-8 py-2 rounded-r-full bg-blue-300 hover:bg-blue-400 text-white font-bold transition-colors text-xs sm:text-sm md:text-base whitespace-nowrap">
            SEND
          </button>
        </div>
      </div>

      {/* Right section - Navigation links */}
      <div class="flex flex-col justify-center items-start sm:items-end space-y-0.5 sm:space-y-1 order-2 sm:order-3 col-span-1 sm:col-span-1">
        <a href="/" class="hover:underline transition-all text-xs sm:text-sm md:text-base">→ HOME</a>
        <a href="/about" class="hover:underline transition-all text-xs sm:text-sm md:text-base">→ ABOUT US</a>
        <a href="/pricing" class="hover:underline transition-all text-xs sm:text-sm md:text-base">→ PRICING</a>
        <a href="/support" class="hover:underline transition-all text-xs sm:text-sm md:text-base">→ SUPPORT CENTER</a>
      </div>
    </div>

    {/* Copyright and footer links */}
    <div class="border-t border-white border-opacity-30 pt-4 sm:pt-6">
      <div class="flex flex-col sm:flex-row justify-between items-center space-y-2 sm:space-y-0 text-center sm:text-left">
        <p class="text-xs text-opacity-80 order-2 sm:order-1">© 2026 WorkGlobal. All rights reserved.</p>
        
        <div class="flex flex-wrap gap-1 sm:gap-3 md:gap-4 text-xs justify-center order-1 sm:order-2">
          <a href="/legal" class="underline hover:no-underline transition-all">Term & Conditions</a>
          <span class="text-opacity-50 hidden sm:inline">|</span>
            <a href="/privacy" class="underline hover:no-underline transition-all">Privacy Policy</a>
          <span class="text-opacity-50 hidden sm:inline">|</span>
            <a href="/legal" class="underline hover:no-underline transition-all">Security</a>
          <span class="text-opacity-50 hidden sm:inline">|</span>
            <a href="/legal" class="underline hover:no-underline transition-all">Manage Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  footer a {
    transition: all 0.3s ease;
  }
</style>
