---
// about.astro — About Us / Behind Work Global page
import Layout from '../layouts/Layout.astro';
import bgImage from '../assets/background.png?url';
import TeamCard from '../components/TeamCard.astro';
import unilever from '../assets/unilever.png?url';
import careem from '../assets/careem.png?url';
import qatarairways from '../assets/qatarairways.png?url';
import engro from '../assets/engro.jpg?url';
import systemslimited from '../assets/nestle.jpg?url';
import jazz from '../assets/jazz.jpg?url';
import farmfoods from '../assets/farmfoods.png?url';
import tesco from '../assets/tesco.png?url';

// ─── Team data — edit freely ───────────────────────────
const team = [
  { name: 'Unilever', role: 'Trusted Client', details: 'A multinational brand delivering everyday consumer products across food, hygiene, and beauty.', image: unilever },
  { name: 'Careem', role: 'Trusted Client', details: 'A leading ride-hailing and delivery platform across the Middle East and South Asia.', image: careem },
  { name: 'Qatar Airways', role: 'Trusted Client', details: 'A world-renowned airline offering premium international passenger and cargo services across a global network.', image: qatarairways },
  { name: 'Engro Corp', role: 'Trusted Client', details: 'One of Pakistan’s leading conglomerates, highly respected for engineering, energy, and agriculture-sector careers.', image: engro },
  { name: 'Nestle Pakistan', role: 'Trusted Client', details: 'A top FMCG employer offering stable careers, competitive salaries, and strong training programs.', image: systemslimited },
  { name: 'Jazz', role: 'Trusted Client', details: 'Pakistan’s largest digital communications company providing mobile connectivity and digital services nationwide.', image: jazz },
  { name: 'Farmfoods Ltd', role: 'Trusted Client', details: 'A UK supermarket chain with nationwide recruitment for retail and distribution roles.', image: farmfoods },
  { name: 'Tesco', role: 'Trusted Client', details: 'One of the UK’s largest supermarket retailers with ongoing job opportunities.', image: tesco },
];

/*
 * Card positions are hand-tuned to match the reference image:
 * a globe centred in the scene, cards orbiting it on an elliptical path.
 * The globe sits at ~50% horizontally, ~60% vertically inside .orbit-scene.
 * Positions are percentages of the scene container (900 × 560 px).
 *
 * Each entry: { x, y } = top-left corner of the card as % of scene dims.
 * Cards are 120px wide × ~160px tall.
 */
const positions = [
  // top wavy line (4 cards)
  { x: 5, y: 10 },    // left
  { x: 33, y: 22 },   // center-left (moved up 2, right 3)
  { x: 56, y: 11 },   // center-right
  { x: 83, y: 20 },   // right
  // bottom wavy line (4 cards)
  { x: 3,  y: 63 },   // far left (moved 2 down)
  { x: 28, y: 58 },   // left (moved 2 down)
  { x: 56, y: 66 },   // right (moved 2 down + 4 right)
  { x: 85, y: 58 },   // far right (moved 2 down)
];
---

<Layout title="About Us - WorkGlobal" navActive="about">
  <style define:vars={{ bgImage: `url(${bgImage})` }}>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #053F5C;
      --light-blue: #86C5FF;
      --bg: #ddeef8;
    }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--bg);
      min-height: 100vh;
    }

    /* ── page background image ── */
    .bg-layer {
      position: fixed;
      inset: 0;
      background-image: var(--bgImage);
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      opacity: 1;
      z-index: -1;
      pointer-events: none;
    }

    /* ── page layout ── */
    .about-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: clamp(150px, 16vw, 190px) 24px 80px;
      min-height: 100vh;
    }

    /* ── header ── */
    .about-header {
      text-align: center;
      max-width: 680px;
      margin-bottom: 48px;
    }

    .about-header h1 {
      font-size: 2.2rem;
      font-weight: 900;
      color: var(--navy);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 16px;
    }

    .about-header p {
      font-size: 0.92rem;
      font-weight: 600;
      color: #4a6a80;
      line-height: 1.7;
    }

    /* ── orbit scene container ── */
    .orbit-scene {
      position: relative;
      width: 100%;
      max-width: 960px;
      /* fixed aspect ratio so % positions work consistently */
      aspect-ratio: 960 / 580;
    }

    /* ── the circle ── */
    .globe-wrap {
      position: absolute;
      /* centre of scene */
      top: 50%;
      left: 50%;
      transform: translate(-50%, -46%);
      /* circle is slightly smaller now (~46% of scene width) */
      width: 46%;
      aspect-ratio: 1;
      border-radius: 50%;
      /* dark bluish gradient centered on #053F5C */
      background: radial-gradient(circle at 34% 26%, #2b79b8 0%, #1a5f77 30%, #053F5C 60%, #01292f 100%);
      /* keep subtle bluish glow, white ring removed */
      box-shadow: 
        0 0 80px rgba(5, 63, 92, 0.32),
        0 0 60px rgba(5, 63, 92, 0.26),
        0 0 40px rgba(5, 63, 92, 0.18),
        0 12px 40px rgba(5, 63, 92, 0.2),
        inset -20px -20px 60px rgba(0, 0, 0, 0.12);
      will-change: transform, box-shadow;
      overflow: hidden;
      z-index: 2;
    }

    .globe-wrap::before {
      content: '';
      position: absolute;
      inset: -14%;
      border-radius: 50%;
      background:
        radial-gradient(circle at 36% 28%, rgba(5, 63, 92, 0.34) 0%, rgba(5, 63, 92, 0.12) 32%, rgba(5, 63, 92, 0) 58%),
        radial-gradient(circle at 74% 76%, rgba(2, 41, 47, 0.14) 0%, rgba(2, 41, 47, 0) 52%);
      pointer-events: none;
      opacity: 0.95;
    }

    @keyframes circle-float {
      0%, 100% {
        transform: translate(-50%, -46%);
      }
      50% {
        transform: translate(-50%, -48.3%);
      }
    }

    @keyframes circle-glow {
      0%, 100% {
        box-shadow:
          0 0 80px rgba(5, 63, 92, 0.4),
          0 0 60px rgba(5, 63, 92, 0.3),
          0 0 40px rgba(5, 63, 92, 0.2),
          0 15px 50px rgba(5, 63, 92, 0.35),
          inset -30px -30px 80px rgba(0, 0, 0, 0.2);
      }
      50% {
        box-shadow:
          0 0 95px rgba(5, 63, 92, 0.46),
          0 0 72px rgba(5, 63, 92, 0.36),
          0 0 52px rgba(5, 63, 92, 0.25),
          0 20px 58px rgba(5, 63, 92, 0.4),
          inset -24px -24px 70px rgba(0, 0, 0, 0.18);
      }
    }



    /* ── cards positioned absolutely ── */
    .card-slot {
      position: absolute;
      /* fixed card size for consistent layout */
      width: 140px !important;
      height: 140px !important;
      z-index: 4;
      animation: card-float 3s ease-in-out infinite;
      will-change: transform;
      border: none;
      background: transparent;
      padding: 0;
      text-align: left;
      cursor: pointer;
    }

    .card-slot .card-body {
      transition: transform 0.2s ease, filter 0.2s ease;
      transform-origin: center;
      width: 100% !important;
      height: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
      box-sizing: border-box !important;
    }

    .card-slot:hover .card-body,
    .card-slot:focus-visible .card-body {
      transform: scale(1.06);
      filter: drop-shadow(0 10px 18px rgba(5, 63, 92, 0.2));
    }

    .card-slot.active {
      z-index: 10;
    }

    .card-slot.active .card-body {
      transform: scale(1.18);
      filter: drop-shadow(0 14px 24px rgba(5, 63, 92, 0.3));
    }

    .card-slot:focus-visible {
      outline: 3px solid rgba(134, 197, 255, 0.9);
      outline-offset: 3px;
      border-radius: 14px;
    }

    @keyframes card-float {
      0%, 100% {
        transform: translateY(0px);
      }
      50% {
        transform: translateY(-8px);
      }
    }

    /* ── wave 1 tilt ── */
    .card-slot:nth-child(3) { animation: card-float-1 3s ease-in-out infinite; }  /* 1st card - left tilt */
    .card-slot:nth-child(4) { animation: card-float-2 3s ease-in-out infinite; }  /* 2nd card - right tilt */
    .card-slot:nth-child(5) { animation: card-float-3 3s ease-in-out infinite; }  /* 3rd card - left tilt */
    .card-slot:nth-child(6) { animation: card-float-4 3s ease-in-out infinite; }  /* 4th card - right tilt */

    /* ── wave 2 tilt ── */
    .card-slot:nth-child(7) { animation: card-float-1 3s ease-in-out infinite; }  /* 5th card - left tilt */
    .card-slot:nth-child(8) { animation: card-float-2 3s ease-in-out infinite; }  /* 6th card - right tilt */
    .card-slot:nth-child(9) { animation: card-float-3 3s ease-in-out infinite; }  /* 7th card - left tilt */
    .card-slot:nth-child(10) { animation: card-float-4 3s ease-in-out infinite; } /* 8th card - right tilt */

    @keyframes card-float-1 {
      0%, 100% { transform: rotate(-8deg) translateY(0px); }
      50% { transform: rotate(-8deg) translateY(-8px); }
    }

    @keyframes card-float-2 {
      0%, 100% { transform: rotate(8deg) translateY(0px); }
      50% { transform: rotate(8deg) translateY(-8px); }
    }

    @keyframes card-float-3 {
      0%, 100% { transform: rotate(-8deg) translateY(-4px); }
      50% { transform: rotate(-8deg) translateY(-12px); }
    }

    @keyframes card-float-4 {
      0%, 100% { transform: rotate(8deg) translateY(-4px); }
      50% { transform: rotate(8deg) translateY(-12px); }
    }

    /* ── curvy bold grey lines above and below circle ── */
    .orbit-scene::before,
    .orbit-scene::after {
      content: '';
      position: absolute;
      left: 50%;
      width: min(94%, 980px);
      height: clamp(100px, 18vw, 170px);
      pointer-events: none;
      opacity: 0.82;
      background-repeat: repeat-x;
      background-size: 100% 100%;
      transform: translateX(-50%);
      z-index: 3;
    }

    @media (max-width: 900px) {
      .card-slot {
        width: 120px;
      }

      .orbit-scene::before {
        top: 20%;
      }

      .orbit-scene::after {
        bottom: 16%;
      }
    }

    .orbit-scene::before {
      top: 18%;
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 700" preserveAspectRatio="none"><path d="M0,350 C200,-300 400,1000 600,350 C800,-300 1000,1000 1200,350" fill="none" stroke="%23B7BDC5" stroke-width="7.2" stroke-linecap="round"/></svg>');
      z-index: 3;
    }

    .orbit-scene::after {
      bottom: 14%;
      background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 700" preserveAspectRatio="none"><path d="M0,350 C200,1000 400,-300 600,350 C800,1000 1000,-300 1200,350" fill="none" stroke="%23B7BDC5" stroke-width="7.2" stroke-linecap="round"/></svg>');
      z-index: 3;
    }

    /* ── responsive fallback: grid below 640px ── */
    @media (max-width: 640px) {
      .orbit-scene {
        aspect-ratio: unset;
        height: auto;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        padding: 16px;
        background: transparent;
      }
      .about-page {
        padding: 136px 16px 56px;
      }
      .globe-wrap,
      .orbit-ring {
        display: none;
      }
      .orbit-scene::before,
      .orbit-scene::after {
        display: none;
      }
      .card-slot,
      .card-slot:nth-child(n) {
        position: static;
        width: 100%;
        animation: none;
        transform: none;
      }

      .card-slot.active .card-body {
        transform: scale(1.04);
      }
    }

    .member-screen {
      width: 100%;
      max-width: 960px;
      margin-top: 36px;
      background: linear-gradient(160deg, rgba(220, 238, 248, 0.95) 0%, rgba(194, 224, 246, 0.95) 100%);
      border: 1px solid rgba(134, 197, 255, 0.6);
      border-radius: 22px;
      box-shadow: 0 16px 45px rgba(5, 63, 92, 0.2);
      padding: 24px;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 24px;
      align-items: center;
    }

    .member-screen[hidden] {
      display: none;
    }

    .member-screen-card {
      background-color: #fff;
      border-radius: 18px;
      padding: 0;
      display: flex;
      align-items: stretch;
      box-shadow: 0 10px 24px rgba(5, 63, 92, 0.14);
      min-height: 240px;
      overflow: hidden;
      background-repeat: no-repeat;
      background-position: center;
      background-size: cover;
    }

    .member-screen-card.is-unilever {
      background-color: #fff;
    }

    .member-screen-avatar {
      width: 100%;
      height: 100%;
      min-height: 240px;
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    .member-screen-content {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .member-screen-title {
      margin: 0;
      color: #053F5C;
      font-size: 1.35rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .member-screen-text {
      margin: 0;
      color: #345d76;
      font-size: 0.95rem;
      font-weight: 600;
      line-height: 1.7;
      max-width: 56ch;
    }

    .member-screen-close {
      width: fit-content;
      border: none;
      border-radius: 999px;
      background: #053F5C;
      color: #fff;
      padding: 9px 16px;
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
    }

    @media (max-width: 760px) {
      .member-screen {
        grid-template-columns: 1fr;
        gap: 16px;
        padding: 18px;
      }

      .member-screen-card {
        width: 100%;
        max-width: 320px;
        margin: 0 auto;
        min-height: 200px;
      }

      .member-screen-card.is-unilever {
        background-size: 135% 100%;
        background-position: center;
      }

      .member-screen-avatar {
        min-height: 200px;
      }

      .member-screen-content {
        align-items: center;
        text-align: center;
      }
    }
  </style>

  <div class="bg-layer"></div>

  <main class="about-page">

    <!-- Header -->
    <div class="about-header">
      <h1>who's hiring on workglobal?</h1>
      <p>
        Join thousands of professionals and top companies who are already using workglobal. Don't Be Late to the Party. If you still aren't using workglobal you are going to be standing outside in the digital cold while everyone else is inside landing interviews.
      </p>
    </div>

    <!-- Globe + Cards -->
    <div class="orbit-scene">



      <!-- Blue circle in center -->
      <div class="globe-wrap"></div>

      <!-- Team cards placed at pre-calculated orbit positions -->
      {team.map((member, i) => (
        <button
          class="card-slot"
          type="button"
          data-member-name={member.name}
          data-member-role={member.role}
          data-member-details={member.details}
          data-member-image={member.image ?? ''}
          aria-label={`Open details for ${member.name}`}
          style={`
            left: ${positions[i]?.x ?? 10}%;
            top:  ${positions[i]?.y ?? 10}%;
          `}
        >
          <div class="card-body">
            <TeamCard name={member.name} image={member.image} />
          </div>
        </button>
      ))}

    </div>

    <section class="member-screen" id="member-screen" hidden>
      <div class="member-screen-card" id="member-screen-card">
        <div class="member-screen-avatar" id="member-screen-avatar"></div>
      </div>

      <div class="member-screen-content">
        <h3 class="member-screen-title">Details</h3>
        <p class="member-screen-text" id="member-screen-text">
          Select a card to view member details.
        </p>
        <button type="button" class="member-screen-close" id="member-screen-close">Close Details</button>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const setupMemberDetails = () => {
        const cards = Array.from(document.querySelectorAll('.card-slot'));
        const screen = document.getElementById('member-screen');
        const cardEl = document.getElementById('member-screen-card');
        const textEl = document.getElementById('member-screen-text');
        const avatarEl = document.getElementById('member-screen-avatar');
        const closeBtn = document.getElementById('member-screen-close');

        if (!cards.length || !screen || !cardEl || !textEl || !avatarEl || !closeBtn) return;

        let activeCard = null;

        const closeDetails = () => {
          cards.forEach((c) => c.classList.remove('active'));
          cardEl.style.backgroundImage = 'none';
          cardEl.classList.remove('is-unilever');
          avatarEl.removeAttribute('aria-label');
          screen.hidden = true;
          activeCard = null;
        };

        cards.forEach((card) => {
          if (card.dataset.bound === 'true') return;
          card.dataset.bound = 'true';

          card.addEventListener('click', () => {
            if (activeCard === card && !screen.hidden) {
              closeDetails();
              return;
            }

            cards.forEach((c) => c.classList.remove('active'));
            card.classList.add('active');
            activeCard = card;

            const name = card.getAttribute('data-member-name') || 'Employee Name';
            const details = card.getAttribute('data-member-details') || 'Supports WorkGlobal across strategy, product, and operations.';
            const image = card.getAttribute('data-member-image') || '';

            textEl.textContent = details;

            cardEl.classList.toggle('is-unilever', name === 'Unilever');

            if (image) {
              cardEl.style.backgroundImage = `url("${image}")`;
              avatarEl.setAttribute('aria-label', `${name} logo`);
            } else {
              cardEl.style.backgroundImage = 'none';
              avatarEl.removeAttribute('aria-label');
            }

            screen.hidden = false;
            screen.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        });

        if (closeBtn.dataset.bound !== 'true') {
          closeBtn.dataset.bound = 'true';
          closeBtn.addEventListener('click', closeDetails);
        }
      };

      document.addEventListener('astro:page-load', setupMemberDetails);
      setupMemberDetails();
    })();
  </script>
</Layout>
