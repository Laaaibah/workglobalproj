    ],
  },
  {
    navLabel: 'Indemnification',
    title: 'Indemnification',
    updated: 'Updated April 17, 2026',
    heading: 'Indemnification',
    content: [
      `You agree to defend, indemnify, and hold harmless Workglobal, Resource Pool Group Ltd, and its officers, directors, employees, and agents, from and against any and all claims, damages, obligations, losses, liabilities, costs, or debt, and arising from: (a) your use of and access to the Platform; (b) your violation of any term of these Terms; (c) your violation of any third-party right, including without limitation any copyright, property, or privacy right; or (d) any claim that your User Content caused damage to a third party.`,
    ],
  },
  {
    navLabel: 'Account Termination',
