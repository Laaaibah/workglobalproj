];
---

<Layout title="Terms and Conditions" navActive="">
  <div class="bg-layer" aria-hidden="true" style="background-image:var(--bgImage)"></div>

  <main class="legal-page">
    <aside class="legal-nav" aria-label="Terms topics">
      <ul>
        {legalSections.map((section, index) => (
          <li>
            <button
              class={`legal-nav-btn${index === 0 ? ' is-active' : ''}`}
              data-tab={index}
              aria-controls={`panel-${index}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              type="button"
            >
              <span class="dot">{index + 1}</span>
              <span>{section.navLabel}</span>
            </button>
          </li>
        ))}
      </ul>
    </aside>

    <section class="legal-content-wrap">
      {legalSections.map((section, index) => (
        <article
          id={`panel-${index}`}
          class={`legal-panel${index === 0 ? ' is-active' : ''}`}
          data-panel={index}
          hidden={index !== 0}
        >
          <h1>{section.title}</h1>
          <p class="updated">{section.updated}</p>
          <h2>{section.heading}</h2>
          {section.content.map((item) => <p>{item}</p>)}
        </article>
      ))}
      <footer class="legal-footer">Last updated: April 17, 2026</footer>
    </section>
  </main>

  <style define:vars={{ bgImage: `url(${bgImage})` }}>
    .bg-layer {
      position: fixed;
      inset: 0;
      background-image: var(--bgImage);
      background-size: cover;
      background-position: center;
      z-index: -1;
      pointer-events: none;
    }

    .legal-page {
      width: min(1080px, 92vw);
      margin: clamp(80px, 10vw, 140px) auto clamp(30px, 4vw, 50px);
      background: #86C5FF;
      border: 1px solid rgba(22, 43, 67, 0.08);
      border-radius: 12px;
      box-shadow: 0 20px 50px rgba(5, 63, 92, 0.15);
      display: grid;
      grid-template-columns: minmax(220px, 30%) 1fr;
      overflow: hidden;
    }

    .legal-nav {
      background: #e6edf0;
      border-right: 1px solid rgba(22, 43, 67, 0.08);
      padding: 22px 14px;
    }

    .legal-nav ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }

    .legal-nav-btn {
      width: 100%;
      border: 0;
      background: transparent;
      text-align: left;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 8px;
      color: #6c8d95;
      font-size: 1rem;
      font-weight: 700;
      border-radius: 8px;
      cursor: pointer;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .legal-nav-btn .dot {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.78rem;
      font-weight: 800;
      background: #b6e7ea;
      color: #1a6b75;
      flex-shrink: 0;
    }

    .legal-nav-btn.is-active,
    .legal-nav-btn:hover {
      color: #053F5C;
      background: rgba(5, 63, 92, 0.06);
    }

    .legal-content-wrap {
      padding: clamp(24px, 3vw, 38px);
      background: transparent;
    }

    .legal-panel {
      color: #053F5C;
      line-height: 1.7;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.24s ease, transform 0.24s ease;
    }

    .legal-panel.is-active {
      opacity: 1;
      transform: translateY(0);
    }

    .legal-panel h1 {
      margin: 0;
      color: #053F5C;
      font-size: clamp(2rem, 3vw, 2.5rem);
      letter-spacing: 0.01em;
    }

    .updated {
      margin: 4px 0 18px;
      color: #a2a5aa;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .legal-panel h2 {
      margin: 0 0 10px;
      color: #053F5C;
      font-size: 1.5rem;
      border-bottom: 1px solid rgba(5,63,92,0.12);
      padding-bottom: 6px;
    }

    .legal-panel p {
      margin: 0 0 14px;
      color: #053F5C;
      font-weight: 600;
    }

    .legal-footer {
      margin-top: 18px;
      padding-top: 12px;
      border-top: 1px solid rgba(90, 95, 102, 0.2);
      color: #8f949a;
      font-size: 0.9rem;
      font-weight: 700;
    }

    @media (max-width: 860px) {
      .legal-page {
        grid-template-columns: 1fr;
      }

      .legal-nav {
        border-right: 0;
        border-bottom: 1px solid rgba(22, 43, 67, 0.08);
      }

      .legal-nav ul {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 580px) {
      .legal-page {
        width: min(96vw, 1080px);
      }

      .legal-nav ul {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const setupTabs = () => {
        const buttons = Array.from(document.querySelectorAll('.legal-nav-btn'));
        const panels = Array.from(document.querySelectorAll('.legal-panel'));
        if (!buttons.length || !panels.length) return;

        const activateTab = (tabIndex) => {
          buttons.forEach((btn, idx) => {
            const active = idx === tabIndex;
            btn.classList.toggle('is-active', active);
            btn.setAttribute('aria-selected', active ? 'true' : 'false');
          });

          panels.forEach((panel, idx) => {
            const active = idx === tabIndex;
            panel.classList.toggle('is-active', active);
            panel.hidden = !active;
          });

          // Smooth-scroll the activated panel to the top of the visible card area
          const target = panels[tabIndex];
          if (target) {
            // small timeout to allow layout/visibility changes to take effect
            setTimeout(() => {
              const topOffset = 12; // px gap from top
              const rect = target.getBoundingClientRect();
              const absoluteTop = window.scrollY + rect.top - topOffset;
              window.scrollTo({ top: absoluteTop, behavior: 'smooth' });
            }, 60);
          }
        };

        buttons.forEach((btn, idx) => {
          btn.addEventListener('click', () => activateTab(idx));
        });
      };

      document.addEventListener('astro:page-load', setupTabs);
      setupTabs();
    })();
  </script>
</Layout>
